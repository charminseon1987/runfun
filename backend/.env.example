APP_ENV=development
SECRET_KEY=your-secret-key-here
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Supabase → Project Settings → Database → Connection string (URI)
# 비밀번호에 @ # 등 특수문자가 있으면 URL 인코딩 필요
# 마이그레이션(alembic)은 보통 Direct connection(5432) 권장. sslmode=require 유지
DATABASE_URL=postgresql+psycopg://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Redis 미사용 시 그대로 두거나 compose로만 띄움
REDIS_URL=redis://localhost:6379/0

# Anthropic — https://console.anthropic.com/ (FRIDGY Vision / 텍스트 에이전트 공통)
ANTHROPIC_API_KEY=
# Vision 지원 모델 권장. 모델 목록: https://docs.anthropic.com/en/docs/about-claude/models
CLAUDE_MODEL=claude-sonnet-4-20250514

GOOGLE_MAPS_API_KEY=

FIREBASE_CREDENTIALS_PATH=

# 냉장고 이미지 Supabase Storage (선택 — 없으면 data URL로 YOLO/Claude 처리)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
FRIDGE_STORAGE_BUCKET=fridge-images

# 로컬 YOLO 마이크로서비스 (Docker 외: http://localhost:8001)
YOLO_SERVICE_URL=http://localhost:8001
