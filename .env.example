# Root / backend/.env 로 복사해 사용 (또는 backend/.env.example 참고)

APP_ENV=development
SECRET_KEY=change-me-in-production-use-long-random-string
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Supabase PostgreSQL (대시보드 URI 기준, sslmode=require)
DATABASE_URL=postgresql+psycopg://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

REDIS_URL=redis://localhost:6379/0

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google Cloud: Maps SDK for Android(필수) / Maps SDK for iOS(선택) 활성화 + 결제 연동.
# 형식: GOOGLE_MAPS_API_KEY=키값 (등호 양옆 공백 없음)
#
# Expo Go(Android)로만 실행하면 .env 키가 네이티브 앱에 포함되지 않아 지도가 회색일 수 있음.
# → `npm run run:android` (또는 `npx expo run:android`) 로 개발 빌드 후 실행.
# 앱 패키지명: com.runmate.runfun — 키에 Android 앱 제한을 쓸 때 이 패키지 + 디버그 SHA-1 등록.
GOOGLE_MAPS_API_KEY=

FIREBASE_CREDENTIALS_PATH=

# 백엔드 (선택)
API_BASE_URL=http://localhost:8000/v1
WS_BASE_URL=ws://localhost:8000

# Expo 앱 → 백엔드 (코스 썸네일 등). 에뮬레이터는 10.0.2.2:8000, 실기기는 PC LAN IP
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/v1
